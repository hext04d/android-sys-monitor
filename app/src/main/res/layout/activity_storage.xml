<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/title_storage"
        app:titleTextColor="?attr/colorOnPrimary"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressStorage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                app:indicatorSize="200dp"
                app:trackThickness="16dp"
                app:trackCornerRadius="8dp" />

            <TextView
                android:id="@+id/tvStorage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:layout_marginBottom="32dp"
                tools:text="32 GB / 64 GB livres" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:text="@string/btn_clear_cache"
                app:icon="@android:drawable/ic_menu_delete"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distribuição de Uso"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/storage_category_images" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <TextView android:id="@+id/tvStorageImages" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/calculating" android:textAppearance="?attr/textAppearanceTitleMedium" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/storage_category_videos" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <TextView android:id="@+id/tvStorageVideos" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/calculating" android:textAppearance="?attr/textAppearanceTitleMedium" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/storage_category_music" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <TextView android:id="@+id/tvStorageMusic" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/calculating" android:textAppearance="?attr/textAppearanceTitleMedium" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/storage_category_docs" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <TextView android:id="@+id/tvStorageDocs" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/calculating" android:textAppearance="?attr/textAppearanceTitleMedium" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/storage_category_apks" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <TextView android:id="@+id/tvStorageApks" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/calculating" android:textAppearance="?attr/textAppearanceTitleMedium" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/storage_category_apps" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <TextView android:id="@+id/tvStorageApps" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/calculating" android:textAppearance="?attr/textAppearanceTitleMedium" android:layout_marginBottom="12dp"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>